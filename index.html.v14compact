<script>
// 自动刷新：每30秒
let refreshTimer=null;
const REFRESH_INTERVAL=30000;

async function refreshData(){
  const el=document.getElementById('refreshing');
  if(el){el.style.display='inline';el.textContent='⟳ 刷新中';el.className='spin'}
  try{
    // 实际项目中这里fetch真实API
    // const r=await fetch('/api/dash_data.json');
    // const d=await r.json();
    // updateUI(d);
    // 更新时间显示
    const now=new Date();
    const ts=now.toLocaleTimeString('zh-CN',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
    const utEl=document.getElementById('ut');
    if(utEl)utEl.textContent=ts;
  }catch(e){
    console.warn('Refresh failed:',e);
  }
  if(el){el.className='';el.textContent='✓ 已更新';setTimeout(()=>{if(el)el.style.display='none'},2000)}
}

// 启动定时刷新
setTimeout(refreshData,REFRESH_INTERVAL);

// 鼠标悬停滚动条显示
document.querySelectorAll('.ntrack2').forEach(el=>{
  el.addEventListener('mouseenter',()=>{el.style.overflowX='scroll'});
  el.addEventListener('mouseleave',()=>{el.style.overflowX='hidden'});
});
</script>
<script>
// ─── 真实API轮询 ───
const API_URL=(location.hostname==='localhost'||location.hostname==='127.0.0.1')?'http://'+location.host+'/api/data':null;
async function poll(){
  if(!API_URL){const t=new Date().toLocaleTimeString('zh-CN',{hour12:false});const e=document.getElementById('ut');if(e)e.textContent=t;return;}
  const el=document.getElementById('refreshing');
  if(el){el.style.display='inline';el.textContent='⟳';el.className='spin';}
  try{
    const r=await fetch(API_URL+'?t='+Date.now());
    const d=await r.json();
    if(d&&d.updated){
      const utEl=document.getElementById('ut');
      if(utEl)utEl.textContent=d.updated.split(' ')[1]||d.updated;
      console.log('Data updated:',d.updated,'News:',(d.news||[]).length,'Sectors:',(d.sectors||[]).length);
    }
  }catch(e){console.warn('Poll failed:',e.message);}
  if(el){el.className='';el.textContent='OK';setTimeout(()=>{if(el)el.style.display='none';},1500);}
}
setTimeout(poll,1000);setInterval(poll,30000);</script></body>
