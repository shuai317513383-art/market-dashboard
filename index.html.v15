<div class="ftr"><div class="ft f0"><b>[SUMMARY] 行情概述</b><span>AI算力/半导体主线强势 医疗/贵金属/军工启动</span></div><div class="ft f1"><b>[RISK] 风险提示</b><span>热度69° 贪婪 科创/AI高位 注意获利了结</span></div><div class="ft f2"><b>[OPPORTUNITY] 机会方向</b><span>贵金属/军工启动 低空/数字经济持续发酵</span></div></div>
</div>
<script>
var lastData=null;
function fetchData(){fetch('/api/data').then(function(r){return r.text()}).then(function(t){try{var d=JSON.parse(t);lastData=d;updateUI(d)}catch(e){}}).catch(function(){})}
function updateUI(d){
  if(!d||!d.indices)return;
  var icEls=document.querySelectorAll('.ic');
  icEls.forEach(function(el){
    var nm=el.querySelector('.icn').textContent;
    var code='';
    for(var k in d.indices){if(d.indices[k].name&&d.indices[k].name.indexOf(nm)>=0){code=k;break}}
    if(code&&d.indices[code]){
      var c=parseFloat(d.indices[code].change||0);
      var p=d.indices[code].price||'---';
      el.querySelector('.icp').textContent=p;
      var cc=el.querySelector('.icc');
      cc.textContent=(c>=0?'+':'')+c.toFixed(2)+'%';
      var col=c>0?'ff4040':c<0?'00c060':'3a5060';
      el.querySelector('.icp').style.color='#'+col;
      cc.style.color='#'+col;
    }
  });
  var ut=document.getElementById('ut');
  if(ut&&d.updated)ut.textContent=d.updated;
  var ht=document.getElementById('htval');
  if(ht&&d.heat!==undefined){
    ht.textContent=d.heat+'\u00b0 '+(d.hlbl||'');
    var hb=document.querySelector('.hbar');
    if(hb)hb.style.width=d.heat+'%';
    var hc=d.hcol||'ff4040';
    if(hb)hb.style.background='#'+hc;
    if(ht)ht.style.color='#'+hc;
  }
}
function poll(){fetchData()}
setTimeout(poll,500);
setInterval(poll,30000);

</script>
